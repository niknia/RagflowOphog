{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=rag.db"
  },
  "LLMProvider": {
    "Provider": "Ollama"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "ChatModel": "qwen3",
    "EmbeddingModel": "bge-m3"
  },
  "Xinference": {
    "BaseUrl": "http://localhost:9997",
    "ModelUid": "bge-m3",
    "ChatModelUid": "qwen2.5-instruct",
    "EmbeddingModelUid": "bge-m3",
    "ApiKey": "EMPTY",
    "Dimensions": 1024,
    "NormalizeEmbeddings": true
  },
  "VectorDatabase": {
    "Provider": "Chroma",
    "DefaultCollection": "knowledge-base"
  },
  "Chroma": {
    "BaseUrl": "http://localhost:8000"
  },
  "Qdrant": {
    "BaseUrl": "http://localhost:6333",
    "ApiKey": ""
  },
  "Search": {
    "Provider": "ElasticSearch"
  },
  "ElasticSearch": {
    "Url": "http://localhost:9200",
    "IndexName": "knowledge-index"
  },
  "Embedding": {
    "Model": "bge-m3",
    "Dimensions": 1024,
    "BatchSize": 16,
    "NormalizeEmbeddings": true
  }
}
